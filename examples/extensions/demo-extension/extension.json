{
  "schemaVersion": 1,
  "id": "demo-extension",
  "name": "Demo Extension",
  "version": "0.1.0",
  "description": "Example Ola extension with a declarative HTTP tool.",
  "permissions": {
    "network": ["https://jsonplaceholder.typicode.com"]
  },
  "tools": [
    {
      "name": "get_post",
      "description": "Fetch a demo post by id with a declarative HTTP GET tool.",
      "kind": "http",
      "inputSchema": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Post id, for example 1"
          }
        },
        "required": ["id"]
      },
      "http": {
        "method": "GET",
        "url": "https://jsonplaceholder.typicode.com/posts/{{input.id}}"
      }
    }
  ]
}
