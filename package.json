{
  "name": "ola",
  "version": "1.0.3",
  "description": "Ola - 新一代 AI 多智能体协作平台。打破传统 GUI 操作模式，将繁琐的跨应用操作、数据处理和日常工作流，简化为最符合人类本能的自然语言对话。意图即界面，语言即生产力。",
  "main": "./out/main/index.js",
  "author": "Leevity team",
  "homepage": "https://lbxai.cn/",
  "packageManager": "npm@10.9.2",
  "engines": {
    "node": ">=22",
    "npm": ">=10"
  },
  "scripts": {
    "preinstall": "node ./scripts/assert-npm-package-manager.mjs",
    "predev": "node ./scripts/predev.mjs",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint --cache .",
    "lint:ci": "eslint --cache . --max-warnings=0",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "verify:message-windowing": "node ./scripts/verify-message-windowing.mjs",
    "verify:chat-experience": "esbuild tools/verify-chat-experience.ts --bundle --platform=node --format=esm --outfile=node_modules/.cache/ola-verify-chat-experience.mjs && node node_modules/.cache/ola-verify-chat-experience.mjs",
    "verify:browser-cookie-import": "esbuild tools/verify-browser-cookie-import.ts --bundle --platform=node --format=esm --external:electron --external:better-sqlite3 --outfile=node_modules/.cache/ola-verify-browser-cookie-import.mjs && node node_modules/.cache/ola-verify-browser-cookie-import.mjs",
    "verify:ai-coding-config": "esbuild tools/verify-ai-coding-config.ts --bundle --platform=node --format=esm --outfile=node_modules/.cache/ola-verify-ai-coding-config.mjs && node node_modules/.cache/ola-verify-ai-coding-config.mjs",
    "verify:ai-coding-terminal": "esbuild tools/verify-ai-coding-terminal.ts --bundle --platform=node --format=esm --outfile=node_modules/.cache/ola-verify-ai-coding-terminal.mjs && node node_modules/.cache/ola-verify-ai-coding-terminal.mjs",
    "verify:ssh-store-modules": "esbuild tools/verify-ssh-store-modules.ts --bundle --platform=node --format=esm --outfile=node_modules/.cache/ola-verify-ssh-store-modules.mjs && node node_modules/.cache/ola-verify-ssh-store-modules.mjs",
    "verify:ssh-reconnect-logs": "esbuild tools/verify-ssh-reconnect-logs.ts --bundle --platform=node --format=esm --outfile=node_modules/.cache/ola-verify-ssh-reconnect-logs.mjs && node node_modules/.cache/ola-verify-ssh-reconnect-logs.mjs",
    "verify:ssh-transfer-resume": "esbuild tools/verify-ssh-transfer-resume.ts --bundle --platform=node --format=esm --outfile=node_modules/.cache/ola-verify-ssh-transfer-resume.mjs && node node_modules/.cache/ola-verify-ssh-transfer-resume.mjs",
    "verify:ssh-config-integrity": "node --experimental-strip-types tools/verify-ssh-config-integrity.ts",
    "verify:provider-retry": "node ./scripts/verify-provider-retry.mjs",
    "verify:mcp-autoconnect": "node --experimental-strip-types tools/verify-mcp-autoconnect.ts",
    "verify:mcp-ipc-authorization": "node --experimental-strip-types tools/verify-mcp-ipc-authorization.ts",
    "verify:channel-lazy-providers": "node --experimental-strip-types tools/verify-channel-lazy-providers.ts",
    "verify:channel-message-dedup": "esbuild tools/verify-channel-message-dedup.ts --bundle --platform=node --format=esm --outfile=node_modules/.cache/ola-verify-channel-message-dedup.mjs && node node_modules/.cache/ola-verify-channel-message-dedup.mjs",
    "verify:tool-registry-governance": "esbuild tools/verify-tool-registry-governance.ts --bundle --platform=node --format=esm --outfile=node_modules/.cache/ola-verify-tool-registry-governance.mjs && node node_modules/.cache/ola-verify-tool-registry-governance.mjs",
    "verify:extension-directory-atomicity": "node --experimental-strip-types tools/verify-extension-directory-atomicity.ts",
    "verify:cron-skipped-runs": "node --experimental-strip-types tools/verify-cron-skipped-runs.ts",
    "verify:message-locator": "node --experimental-strip-types tools/verify-message-locator.ts",
    "verify:webview-security": "node --experimental-strip-types tools/verify-webview-security.ts",
    "verify:agent-stream-replay": "node --experimental-strip-types tools/verify-agent-stream-replay.ts",
    "verify:agent-run-owner-authorization": "node --experimental-strip-types tools/verify-agent-run-owner-authorization.ts",
    "verify:terminal-owner-isolation": "node --experimental-strip-types tools/verify-terminal-owner-isolation.ts",
    "verify:credential-injection-authorization": "node --experimental-strip-types tools/verify-credential-injection-authorization.ts",
    "verify:desktop-ipc-authorization": "node --experimental-strip-types tools/verify-desktop-ipc-authorization.ts",
    "verify:fs-shell-ipc-authorization": "node --experimental-strip-types tools/verify-fs-shell-ipc-authorization.ts",
    "verify:api-oauth-ipc-authorization": "node --experimental-strip-types tools/verify-api-oauth-ipc-authorization.ts",
    "verify:credential-ssh-remote-ipc-authorization": "node --experimental-strip-types tools/verify-credential-ssh-remote-ipc-authorization.ts",
    "generate:agent-runtime-contract": "node ./scripts/generate-agent-runtime-contract.mjs",
    "verify:agent-runtime-contract": "node --experimental-strip-types tools/verify-agent-runtime-contract.ts",
    "verify:preload-strangler": "node --experimental-strip-types tools/verify-preload-strangler.ts",
    "verify:sync-legacy-migration": "node --experimental-strip-types tools/verify-sync-legacy-migration.ts",
    "verify:team-runtime-jsonl": "node --experimental-strip-types tools/verify-team-runtime-jsonl.ts",
    "verify:webdav-conditional-write": "node --experimental-strip-types tools/verify-webdav-conditional-write.ts",
    "verify:input-drafts": "esbuild tools/verify-input-drafts.ts --bundle --platform=node --format=esm --external:electron --outfile=node_modules/.cache/ola-verify-input-drafts.mjs && node node_modules/.cache/ola-verify-input-drafts.mjs",
    "verify:execution-outline": "esbuild tools/verify-execution-outline.ts --bundle --platform=node --format=esm --outfile=node_modules/.cache/ola-verify-execution-outline.mjs && node node_modules/.cache/ola-verify-execution-outline.mjs",
    "verify:hooks": "esbuild tools/verify-hooks-framework.ts --bundle --platform=node --format=esm --outfile=node_modules/.cache/ola-verify-hooks.mjs && node node_modules/.cache/ola-verify-hooks.mjs",
    "verify:sub-agent-history": "node ./scripts/verify-sub-agent-history.mjs",
    "verify:main-safety": "node --experimental-strip-types tools/check-main-module-safety.ts",
    "verify:permission-policy": "node --experimental-strip-types tools/verify-permission-policy.ts",
    "verify:release-gates": "node --experimental-strip-types tools/verify-release-gates.ts",
    "verify:ci-core": "npm run verify:main-safety && npm run verify:permission-policy && npm run verify:message-windowing && npm run verify:chat-experience && npm run verify:browser-cookie-import && npm run verify:ai-coding-terminal && npm run verify:codegraph-worker && npm run verify:codegraph-dashboard && npm run verify:remote-authorization && npm run verify:remote-credential-lease && npm run verify:ssh-config-integrity && npm run verify:mcp-autoconnect && npm run verify:mcp-ipc-authorization && npm run verify:channel-lazy-providers && npm run verify:channel-message-dedup && npm run verify:tool-registry-governance && npm run verify:extension-directory-atomicity && npm run verify:cron-skipped-runs && npm run verify:message-locator && npm run verify:webview-security && npm run verify:agent-stream-replay && npm run verify:agent-run-owner-authorization && npm run verify:terminal-owner-isolation && npm run verify:credential-injection-authorization && npm run verify:desktop-ipc-authorization && npm run verify:fs-shell-ipc-authorization && npm run verify:api-oauth-ipc-authorization && npm run verify:credential-ssh-remote-ipc-authorization && npm run verify:agent-runtime-contract && npm run verify:preload-strangler && npm run verify:release-gates && npm run verify:sync-legacy-migration && npm run verify:team-runtime-jsonl && npm run verify:webdav-conditional-write",
    "audit:sync": "node ./scripts/audit-opencowork-sync.mjs",
    "audit:sync:check": "node ./scripts/audit-opencowork-sync.mjs --check",
    "audit:sync:write": "node ./scripts/audit-opencowork-sync.mjs --write",
    "verify:sync-audit": "node ./scripts/verify-sync-audit.mjs",
    "verify:remote-store": "node --experimental-strip-types tools/verify-remote-connection-store.ts",
    "verify:remote-test": "node --experimental-strip-types tools/verify-remote-connection-test.ts",
    "verify:remote-authorization": "node --experimental-strip-types tools/verify-remote-authorization.ts",
    "verify:remote-credential-lease": "node --experimental-strip-types tools/verify-remote-credential-lease.ts",
    "verify:remote-server-smoke": "node server/scripts/smoke.mjs",
    "verify:novnc-proxy": "esbuild tools/verify-novnc-proxy.ts --bundle --platform=node --format=cjs --outfile=/tmp/ola-verify-novnc-proxy.cjs && node /tmp/ola-verify-novnc-proxy.cjs",
    "native:publish": "node ./scripts/publish-native-worker.mjs",
    "worker:assets:status": "node ./scripts/validate-worker-assets.mjs",
    "worker:assets:verify": "node ./scripts/validate-worker-assets.mjs --strict",
    "codegraph:grammars:validate": "node ./scripts/validate-codegraph-grammars.mjs",
    "verify:codegraph-worker": "node ./scripts/verify-codegraph-worker.mjs",
    "verify:codegraph-dashboard": "esbuild tools/verify-codegraph-dashboard.ts --bundle --platform=node --format=esm --outfile=node_modules/.cache/ola-verify-codegraph-dashboard.mjs && node node_modules/.cache/ola-verify-codegraph-dashboard.mjs",
    "verify:provider-main-store": "esbuild tools/verify-provider-main-store.ts --bundle --platform=node --format=esm --outfile=node_modules/.cache/ola-verify-provider-main-store.mjs && node node_modules/.cache/ola-verify-provider-main-store.mjs",
    "verify:draw-graph-core": "esbuild tools/verify-draw-graph-core.ts --bundle --platform=node --format=esm --outfile=node_modules/.cache/ola-verify-draw-graph-core.mjs && node node_modules/.cache/ola-verify-draw-graph-core.mjs",
    "verify:draw-image-ops": "esbuild tools/verify-draw-image-ops.ts --bundle --platform=node --format=esm --outfile=node_modules/.cache/ola-verify-draw-image-ops.mjs && node node_modules/.cache/ola-verify-draw-image-ops.mjs",
    "verify:draw-projects": "esbuild tools/verify-draw-projects.ts --bundle --platform=node --format=esm --outfile=node_modules/.cache/ola-verify-draw-projects.mjs && node node_modules/.cache/ola-verify-draw-projects.mjs",
    "verify:draw-canvas-assistant": "esbuild tools/verify-draw-canvas-assistant.ts --bundle --platform=node --format=esm --outfile=node_modules/.cache/ola-verify-draw-canvas-assistant.mjs && node node_modules/.cache/ola-verify-draw-canvas-assistant.mjs",
    "verify:media-runtime": "esbuild tools/verify-media-runtime.ts --bundle --platform=node --format=esm --outfile=node_modules/.cache/ola-verify-media-runtime.mjs && node node_modules/.cache/ola-verify-media-runtime.mjs",
    "start": "electron-vite preview",
    "dev": "node ./scripts/launch-dev.mjs",
    "dev:raw": "electron-vite dev",
    "build": "npm run typecheck && electron-vite build",
    "postinstall": "node ./scripts/postinstall.mjs",
    "build:unpack": "npm run build && electron-builder --dir",
    "build:win": "npm run build && electron-builder --win",
    "build:win:green": "npm run build && electron-builder --win zip -c.extraMetadata.olaDistribution=green -c.directories.output=dist-green --publish never",
    "build:mac": "electron-vite build && electron-builder --mac",
    "build:linux": "electron-vite build && electron-builder --linux"
  },
